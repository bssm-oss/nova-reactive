<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd"
             version="3.2">
    <persistence-unit name="bench" transaction-type="RESOURCE_LOCAL">
        <class>io.nova.benchmark.entity.BenchUser</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <!-- jdbc.url / driver / user / password 는 실행 시 backend(H2 / PostgreSQL)별로 주입된다. -->
            <property name="hibernate.hbm2ddl.auto" value="create"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>
            <!-- 단건 연산 위주이므로 batch는 끈다(공정성). -->
            <property name="hibernate.jdbc.batch_size" value="0"/>
            <!-- HikariCP: pool 초과 동시성에서 예외 대신 큐잉(Nova r2dbc-pool과 대등). 양 backend 모두 20. -->
            <property name="hibernate.connection.provider_class"
                      value="org.hibernate.hikaricp.internal.HikariCPConnectionProvider"/>
            <property name="hibernate.hikari.maximumPoolSize" value="20"/>
            <property name="hibernate.hikari.minimumIdle" value="5"/>
        </properties>
    </persistence-unit>

    <!-- Hibernate Reactive(Vert.x, 논블로킹) 전용 PU. jdbc.url/user/password는 런타임 주입. PG 전용. -->
    <persistence-unit name="bench-reactive" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.reactive.provider.ReactivePersistenceProvider</provider>
        <class>io.nova.benchmark.entity.BenchUser</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <property name="hibernate.hbm2ddl.auto" value="create"/>
            <property name="hibernate.show_sql" value="false"/>
            <!-- Vert.x reactive pool size — Nova r2dbc-pool / Hibernate Hikari와 동일하게 20. -->
            <property name="hibernate.connection.pool_size" value="20"/>
        </properties>
    </persistence-unit>
</persistence>
