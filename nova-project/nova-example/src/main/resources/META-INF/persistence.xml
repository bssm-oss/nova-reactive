<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <!--
      Hibernate Reactive requires a persistence-unit declaration even for the
      smallest "two entities" sample. Compare against Nova where wiring lives
      in code right next to the call site.
    -->
    <persistence-unit name="example-pu">
        <provider>org.hibernate.reactive.provider.ReactivePersistenceProvider</provider>

        <class>io.nova.example.hibernate.User</class>
        <class>io.nova.example.hibernate.Order</class>

        <properties>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:postgresql://localhost:5432/example"/>
            <property name="jakarta.persistence.jdbc.user" value="example"/>
            <property name="jakarta.persistence.jdbc.password" value="example"/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="create-drop"/>
            <property name="hibernate.show_sql" value="false"/>
        </properties>
    </persistence-unit>
</persistence>
